# Configurações da API local (seu PC)
API_PORT=3010

# ===================================================================
# Credenciais e Endereço do MikroTik (acessado DIRETAMENTE via WireGuard)
# O WireGuard cria uma rede virtual onde 10.199.0.3 é acessível.
# ===================================================================
MIKROTIK_HOST=10.199.0.3  # O IP INTERNO REAL do MikroTik na rede VPN
MIKROTIK_PORT=443         # A porta da API REST no MikroTik
MIKROTIK_USER=API1
MIKROTIK_PASS=Blocked@@99

# Configurações do Banco de Dados PostgreSQL (ainda o externo, se você o usa diretamente)
# Se você estiver usando um banco de dados local (Docker ou instalado), ajuste.
DB_HOST=69.62.99.122
DB_PORT=5437
DB_USER=hotspotbd
DB_PASS=hotspotbd
DB_NAME=hotspotbd

# Segredo para assinatura do JSON Web Token (JWT)
JWT_SECRET=ESTE_EH_UM_SEGREDO_MUITO_FORTE_E_DEVE_SER_MUDADO

# Configurações do Resend para envio de E-mail (se você quiser testar localmente)
RESEND_API_KEY=sua_chave_de_api_do_resend_aqui
NOTIFICATION_EMAIL_FROM=onboarding@resend.dev
NOTIFICATION_EMAIL_TO=email_do_admin@exemplo.com

# Variável para o Frontend (se ele estiver rodando LOCALMENTE, ex: Next.js dev server)
# O frontend local acessa a API local
NEXT_PUBLIC_API_URL=http://localhost:3010/api